# =================================================================
# DYNAMIC MICROSERVICE ROUTING CONFIGURATION
# =================================================================
# You can route different parts of the AI pipeline to different 
# servers (like Google Colab via ngrok for GPUs, and localhost for CPUs).
# 
# Instructions:
# 1. Rename this file to `.env`
# 2. Update the Ngrok URLs to match your currently running Colab notebooks.
# 3. The backend orchestrator will automatically pick up these changes
#    and route the requests dynamically!

# -----------------------------------------------------------------
# GPU MODELS (Deployed on Google Colab via Ngrok)
# -----------------------------------------------------------------
# Frame Extraction usually needs GPU for fast video decoding
MICROSERVICE_FRAME_EXTRACTION_URL=https://your-ngrok-url-1.ngrok-free.app

# Defect Detection (YOLO, etc) strictly needs GPU
MICROSERVICE_DEFECT_DETECTION_URL=https://your-ngrok-url-2.ngrok-free.app

# Explainability (LLMs/VLMs) usually needs GPU
MICROSERVICE_EXPLAINABILITY_URL=https://your-ngrok-url-3.ngrok-free.app

# -----------------------------------------------------------------
# CPU MODELS (Running Locally)
# -----------------------------------------------------------------
# These lightweight models can run on your local machine.
# If you comment these out, they will default to 127.0.0.1 anyway!
MICROSERVICE_UNIQUE_DEFECTS_URL=http://127.0.0.1:8105
MICROSERVICE_COST_ESTIMATION_URL=http://127.0.0.1:8106
MICROSERVICE_REPORT_GENERATION_URL=http://127.0.0.1:8108
